# Токен бота от @BotFather (строка вида 123456789:ABCdef...)
BOT_TOKEN=your_bot_token_here

# Ваш числовой Telegram ID (команда /myid в боте или @userinfobot)
ADMIN_TELEGRAM_ID=123456789

# URL сервера с HTTPS (после деплоя на Render)
WEBAPP_URL=https://kitchen-bot.onrender.com

# Постоянная БД. Локально можно не задавать — будет SQLite kitchen.db.
# На Render задайте реальную строку Neon только в Environment Variables.
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# true — на Render (webhook), false — локально (polling)
WEBHOOK_MODE=false

# Порт (локально 8000, на Render задаётся автоматически)
API_PORT=8000
